# Copy to .env.local and fill in (never commit .env.local).
# Same Firebase project as RFC CRM: rfc-management
# Console: https://console.firebase.google.com/project/rfc-management

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=rfc-management.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=rfc-management
VITE_FIREBASE_STORAGE_BUCKET=rfc-management.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# OAuth providers — enable in Firebase Console when ready (see src/config/authProviders.example.js)
# VITE_GOOGLE_CLIENT_ID=
# VITE_FACEBOOK_APP_ID=
# VITE_APPLE_CLIENT_ID=
# VITE_PHONE_AUTH_ENABLED=true
